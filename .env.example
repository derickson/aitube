# Elasticsearch Serverless
ELASTICSEARCH_URL=https://your-deployment.es.cloud.elastic.co
ELASTICSEARCH_API_KEY=your-api-key-here

# Anthropic API (for AI summaries and ad detection)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Server
HOST=0.0.0.0
PORT=8000

# Polling age limits (days)
YOUTUBE_MAX_AGE_DAYS=5
PODCAST_MAX_AGE_DAYS=5
RSS_MAX_AGE_DAYS=120

# Elastic APM (Observability - separate from data Elasticsearch)
ELASTIC_APM_SERVER_URL=https://your-apm-endpoint.apm.cloud.elastic.co
ELASTIC_APM_SECRET_TOKEN=your-apm-secret-token
ELASTIC_APM_ENVIRONMENT=development

# Frontend APM RUM (Vite build-time vars, no secret token needed)
VITE_ELASTIC_APM_SERVER_URL=https://your-apm-endpoint.apm.cloud.elastic.co
VITE_ELASTIC_APM_ENVIRONMENT=development
